# Deconstruct AI local environment template
# Copy to .env.local and fill secrets locally. .env.local is ignored by git.

# App
PORT=5000
JWT_SECRET=replace-with-a-long-random-local-secret
INTEGRATION_TIMEOUT_MS=2500

# Local service URLs used by the app when running on the host.
# In Docker Compose, app-to-service traffic uses container DNS names from docker-compose.yml.
# Browser/mobile traffic uses window.location.origin, so use the Tailscale host in the address bar.
N8N_BASE_URL=http://localhost:5678
N8N_WEBHOOK_URL=http://localhost:5678/webhook/deconstruct-ai-generate
N8N_TEMPLATE_RULE_WEBHOOK_URL=http://localhost:5678/webhook/deconstruct-ai-template-rules
FLOWISE_BASE_URL=http://localhost:3000
FLOWISE_CHATFLOW_ID=11111111-1111-4111-8111-111111111111
MCP_HTTP_URL=http://localhost:5001

# PostgreSQL is the authoritative template-rule store. Rules are stored as
# plain multi-line TEXT and retrieved by exact template_id, never by vector
# similarity, so one template cannot inherit another template's visual rule set.
DATABASE_URL=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=deconstruct_ai
POSTGRES_USER=deconstruct_ai
POSTGRES_PASSWORD=replace-with-local-postgres-password

# Budget guardrails: AI image generation is disabled unless explicitly enabled.
ENABLE_REAL_IMAGE_GENERATION=false
GEMINI_DAILY_CAP=10
ENABLE_EXTERNAL_INTEGRATION_CHECKS=false
ENABLE_PINECONE_REMOTE_STATUS=false

# Pinecone is deprecated for template-rule retrieval. Leave unset unless you
# intentionally need legacy read-only status checks during migration.
PINECONE_API_KEY=
PINECONE_INDEX_HOST=
PINECONE_INDEX_NAME=graphics-templates
PINECONE_NAMESPACE=rulesets

# Optional model keys. Do not commit real values.
GEMINI_API_KEY=
GOOGLE_AI_STUDIO_API_KEY=
OPENAI_API_KEY=
